rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Documents
    match /documents/{docId} {
      allow read: if isSignedIn() && isOwner(existing().ownerId);
      allow create: if isSignedIn() && isValidDocument(incoming()) && isOwner(incoming().ownerId);
      allow update: if isSignedIn() && isOwner(existing().ownerId) && isValidDocument(incoming()) 
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'sourceUrl', 'updatedAt'])
        );
      allow delete: if isSignedIn() && isOwner(existing().ownerId);

      function isValidDocument(data) {
        return data.keys().hasAll(['title', 'content', 'sourceUrl', 'courseId', 'ownerId', 'createdAt', 'updatedAt'])
          && data.keys().size() == 7
          && data.title is string && data.title.size() > 0 && data.title.size() <= 200
          && data.content is string && data.content.size() <= 50000
          && data.sourceUrl is string && data.sourceUrl.size() <= 1000
          && data.courseId is string && data.courseId.size() <= 128
          && data.ownerId == request.auth.uid
          && data.createdAt == request.time
          && data.updatedAt == request.time;
      }

      // Highlights subcollection
      match /highlights/{highlightId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/documents/$(docId)).data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && isValidHighlight(incoming(), docId) && isOwner(incoming().userId);
        allow update: if false; // Highlights are typically static or re-created
        allow delete: if isSignedIn() && isOwner(existing().userId);

        function isValidHighlight(data, dId) {
          return data.keys().hasAll(['documentId', 'userId', 'text', 'range', 'createdAt'])
            && data.keys().size() >= 5
            && data.documentId == dId
            && data.userId == request.auth.uid
            && data.text is string && data.text.size() <= 2000
            && data.range is map
            && data.range.start is int && data.range.end is int
            && data.createdAt == request.time;
        }
      }

      // Notes subcollection
      match /notes/{noteId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/documents/$(docId)).data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && isValidNote(incoming(), docId) && isOwner(incoming().userId);
        allow update: if isSignedIn() && isOwner(existing().userId) && isValidNote(incoming(), docId)
          && incoming().userId == existing().userId
          && incoming().createdAt == existing().createdAt
          && (
            incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt'])
          );
        allow delete: if isSignedIn() && isOwner(existing().userId);

        function isValidNote(data, dId) {
          return data.keys().hasAll(['documentId', 'userId', 'content', 'createdAt', 'updatedAt'])
            && data.keys().size() == 5
            && data.documentId == dId
            && data.userId == request.auth.uid
            && data.content is string && data.content.size() <= 10000
            && data.createdAt <= request.time
            && data.updatedAt >= data.createdAt;
        }
      }
    }

    // 2. Courses
    match /courses/{courseId} {
      allow read: if isSignedIn() && isOwner(existing().ownerId);
      allow create: if isSignedIn() && isValidCourse(incoming()) && isOwner(incoming().ownerId);
      allow update: if isSignedIn() && isOwner(existing().ownerId) && isValidCourse(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'updatedAt'])
        );
      allow delete: if isSignedIn() && isOwner(existing().ownerId);

      function isValidCourse(data) {
        return data.keys().hasAll(['title', 'description', 'ownerId', 'createdAt', 'updatedAt'])
          && data.keys().size() == 5
          && data.title is string && data.title.size() > 0 && data.title.size() <= 200
          && data.description is string && data.description.size() <= 1000
          && data.ownerId == request.auth.uid
          && data.createdAt == request.time
          && data.updatedAt == request.time;
      }
    }
  }
}
